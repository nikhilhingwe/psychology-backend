{
  "name": "psychology-backend",
  "version": "1.0.0",
  "description": "Backend for Positive Psychology Daily Messages",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
